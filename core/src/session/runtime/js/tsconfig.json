{
  // Editor-only: type-checks smudgy.ts (the smudgy_ops extension entry) in this folder.
  // smudgy.ts is loaded by the runtime via deno's extension transpiler (type-stripped),
  // NOT compiled here. The author-facing contract is the hand-authored
  // ../script_engine/../models/script_typings/smudgy-core.d.ts; the drift-guard test in
  // models/script_typings.rs keeps this impl and that contract in lockstep.
  "include": ["./smudgy.ts"],
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true
  }
}
