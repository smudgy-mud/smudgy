{
  // Editor-only: type-checks mapper.ts (the smudgy_mapper extension entry) in this folder.
  // mapper.ts is loaded by the runtime via deno's extension transpiler (type-stripped), NOT
  // compiled here. The author-facing mapper contract is the hand-authored, shipped
  // ../../../../models/script_typings/smudgy-mapper.d.ts.
  "include": ["./mapper.ts"],
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true
  }
}
