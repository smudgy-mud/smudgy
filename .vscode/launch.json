{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug executable 'smudgy'",
            "cargo": {
                "args": [
                    "build",
                    "--bin=smudgy",
                    "--package=smudgy_ui"
                ],
                "filter": {
                    "name": "smudgy",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug unit tests in executable 'smudgy'",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--bin=smudgy",
                    "--package=smudgy_ui"
                ],
                "filter": {
                    "name": "smudgy",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug unit tests in library 'smudgy_core'",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--lib",
                    "--package=smudgy_core"
                ],
                "filter": {
                    "name": "smudgy_core",
                    "kind": "lib"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        }
    ]
}